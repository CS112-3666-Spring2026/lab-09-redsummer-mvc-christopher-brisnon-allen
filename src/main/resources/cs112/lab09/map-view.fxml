<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="465.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cs112.lab09.controllers.MapController">
   <children>
      <ImageView fitHeight="465.0" fitWidth="700.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../images/Red-Summer.jpg" />
         </image>
      </ImageView>
      <Button fx:id="SanFransicoCAButton" layoutY="197.0" mnemonicParsing="false" onAction="#onSanFransicoCAButtonClick" text="San Francisco&#10;California" textAlignment="CENTER">
         <font>
            <Font size="10.0" />
         </font>
      </Button>
      <Button fx:id="BisbeeAZButton" layoutX="117.0" layoutY="333.0" mnemonicParsing="false" onAction="#onBisbeeAZButtonClick" text="Bisbee&#10;Arizona&#10;">
         <font>
            <Font size="10.0" />
         </font>
      </Button>
   </children>
</Pane>
